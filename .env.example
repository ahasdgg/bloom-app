# =========================
# TimeBloom / Breath of Fresh Air
# Environment template (SAFE TO COMMIT)
# =========================

# ---- App flags ----
# If true, the app will use fake/anonymized data suitable for demos.
DEMO_MODE=false

# If true, sensitive suggestions are blurred until user reveals.
PRIVACY_BLUR_DEFAULT=true

# ---- LLM (Gemini) ----
LLM_API_KEY=your_gemini_api_key_here
LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/models

# ---- Weather (OpenWeatherMap) ----
WEATHER_API_KEY=your_openweathermap_key_here
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# ---- Maps (Google / Yandex etc.) ----
MAPS_API_KEY=your_maps_key_here

# ---- Optional integrations ----
BOOKING_API_KEY=
BOOKING_API_URL=

# ---- Timeouts ----
API_TIMEOUT=30000
OFFLINE_SYNC_INTERVAL=300000
